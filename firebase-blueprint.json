{
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/thumbnails/{thumbnailId}": {
      "schema": "Thumbnail",
      "description": "Saved thumbnails"
    },
    "/redeem_codes/{code}": {
      "schema": "RedeemCode",
      "description": "Redeemable codes for Premium/Max plans"
    }
  },
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and plan information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "plan": { "type": "string", "enum": ["Free", "Premium", "Max"] },
        "coins": { "type": "integer" },
        "dailyUsage": {
          "type": "object",
          "properties": {
            "1K": { "type": "integer" },
            "2K": { "type": "integer" },
            "4K": { "type": "integer" },
            "8K": { "type": "integer" },
            "total": { "type": "integer" }
          }
        },
        "lastResetDate": { "type": "string", "format": "date" }
      },
      "required": ["uid", "email", "plan"]
    },
    "Thumbnail": {
      "title": "Thumbnail",
      "description": "Saved thumbnails and their canvas state",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "canvasState": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "imageUrl"]
    },
    "RedeemCode": {
      "title": "RedeemCode",
      "description": "Redeemable subscription code",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "plan": { "type": "string", "enum": ["Premium", "Max"] },
        "isUsed": { "type": "boolean" },
        "usedBy": { "type": "string" },
        "usedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "oneTimeUse": { "type": "boolean" }
      },
      "required": ["code", "plan", "isUsed", "createdAt", "createdBy"]
    }
  }
}
